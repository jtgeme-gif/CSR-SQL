# Copy this to .env.local for local development (not committed to git).
# For the live app, these same two values go into Vercel's
# Project Settings -> Environment Variables instead.
#
# Both values come from your Supabase project:
# Project Settings -> API -> Project URL / anon public key

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
